version = "1.0"

[metadata]
difficulty = "{{ difficulty | default('medium') }}"
category = "{{ persona }}"
tags = [{% for tag in tags %}"{{ tag }}"{% if not loop.last %}, {% endif %}{% endfor %}]

[verifier]
timeout_sec = {{ verifier_timeout }}
{% if has_llm_judge %}

[verifier.env]
{{ llm_env_key }} = "${{ '{' }}{{ llm_env_key }}{{ '}' }}"
MODEL_NAME = "{{ model_name | default('') }}"
{% endif %}

[agent]
timeout_sec = {{ agent_timeout }}
setup_timeout_sec = {{ agent_setup_timeout }}

[environment]
build_timeout_sec = {{ build_timeout }}
cpus = {{ cpus }}
memory_mb = {{ memory_mb }}
storage_mb = {{ storage_mb }}
{% if skills_dir %}
skills_dir = "{{ skills_dir }}"
{% endif %}
